rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "wealthwizard1k@gmail.com" ||
        request.auth.token.email == "abdulhadimonu@gmail.com"
      );
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /orders/{orderId} {
      // Allow anyone to create orders (guest checkout)
      allow create: if true;
      // Allow read: owner OR admin
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin());
      // Only admin can update orders (status changes)
      allow update: if isAdmin();
      // Only admin can delete orders
      allow delete: if isAdmin();
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /returnRequests/{returnId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /notifications/{notifId} {
      // Allow read: owner of notification OR admin
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin());
      // Only admin can create notifications (automated system)
      allow create: if isAdmin();
      // Only admin can update/delete notifications
      allow update, delete: if isAdmin();
    }

    match /visitors/{visitorId} {
      allow read: if isAdmin();
      allow write: if true;
    }

    match /visitorLogs/{logId} {
      allow read: if isAdmin();
      allow create: if true;
    }
  }
}
